{
  "expo": {
    "name": "Bida",
    "slug": "bida",
    "scheme": "bida",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bida-icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/bida-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1E3B"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Bida uses your photo library so you can choose a profile photo."
        }
      ]
    ],
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.bida"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/bida-icon.png",
        "backgroundColor": "#0B1E3B"
      },
      "package": "com.anonymous.bida"
    }
  }
}
